{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/quota-guard.mjs\""
          }
        ],
        "description": "Poll local quota snapshots before sending a new prompt."
      }
    ]
  }
}
